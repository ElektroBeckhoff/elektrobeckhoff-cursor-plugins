	TOF								:ARRAY[1..4] OF TOF;
	bTest_West						:BOOL := FALSE;
	bTest_Sued						:BOOL := FALSE;
	bTest_Osten						:BOOL := FALSE;
	bTestSafetyPosition				:BOOL := FALSE;
	bTestSafetyPositionMarkise		:BOOL := FALSE;
	bTest: BOOL;
END_VAR]]></Declaration>
