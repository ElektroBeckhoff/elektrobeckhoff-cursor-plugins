    <Declaration><![CDATA[PROGRAM WeatherStation
VAR
	fbThiesWSC11					:FB_ThiesWSC11;
	fbThiesWSC11Time				:FB_ThiesWSC11Time;
	fbEB_Time						:FB_EB_Time;
	fbThresholdSwitch				:ARRAY[1..8] OF FB_ThresholdSwitch;
	fbWeeklyTimeSwitch				:ARRAY[1..2] OF FB_WeeklyTimeSwitch;
	bResetWSC11						:BOOL;
	bSetTimeManual					:BOOL;

	//FBs für Aktion A_Sonnenposition
	fbCalcSunPosition				:FB_CalcSunPosition;
	fbThresholdswitch_Beschattung	:ARRAY[1..4] OF FB_Thresholdswitch;
